{
  "name": "openclaw-crm-plugin",
  "version": "0.1.1",
  "description": "Personal CRM for OpenClaw — manage contacts, track life events, and get birthday reminders",
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "install": {
      "localPath": "extensions/openclaw-crm-plugin",
      "defaultChoice": "local"
    }
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
